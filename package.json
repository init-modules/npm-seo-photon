{
	"name": "@init/seo-photon",
	"version": "0.1.0",
	"description": "SEO page settings kit for the package-first photon.",
	"type": "module",
	"files": [
		"dist",
		"src"
	],
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "tsup src/index.ts --format esm --dts --clean",
		"check:dist": "npm run build && git diff --exit-code -- dist",
		"prepack": "npm run build"
	},
	"peerDependencies": {
		"@init/seo": "^0.1.0",
		"@init/photon": "^0.1.0",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@init/seo": "file:../seo",
		"@init/photon": "file:../photon-foundation/photon",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"tsup": "^8.5.0",
		"typescript": "^5.9.3"
	},
	"photon": {
		"installableKitExport": "seoPhotonKit"
	}
}
